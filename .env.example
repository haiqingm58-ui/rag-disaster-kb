# ============================================================
# FastAPI Web 应用配置
# ============================================================

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_UPLOAD_MB=30
GRAPH_TOP_K=80
DISASTER_CACHE_TTL_SECONDS=600
LOG_LEVEL=INFO
LOG_TO_FILE=true
# 生产环境建议填写域名，例如：https://example.com；多个用英文逗号分隔。
CORS_ORIGINS=

# 登录与接口安全。生产环境请改成强密码和随机 JWT_SECRET。
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRE_MINUTES=480
CHAT_RATE_LIMIT_PER_MINUTE=30

# 注册功能。注册必须填写邀请码，并通过邮箱验证码校验。
# 当前邀请码规则在 app_server/services/invite_code_service.py：
# opengeorisk + 北京时间当天日期，例如 2026-06-07 为 opengeorisk20260607。
# 注意：前端不要展示该规则，只由管理员告知需要注册的人。
REGISTRATION_DEFAULT_ROLE=admin
REGISTRATION_CODE_EXPIRE_MINUTES=10
REGISTRATION_CODE_SEND_INTERVAL_SECONDS=60

# SMTP 邮件发送。兼容 SMTP_*、SMTP_SERVER、MAIL_*、EMAIL_* 常见命名。
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=12

# ============================================================
# LLM 配置
# ============================================================

# deepseek = DeepSeek API 生成回答；local = 本地 llama-server 生成回答。
LLM_PROVIDER=deepseek

# --- DeepSeek API（默认）---
# 不要把真实 API Key 提交到 GitHub；请只写在本机 .env。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

# --- 本地 llama.cpp server（仅 LLM_PROVIDER=local 时使用）---
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=qwen-local
LOCAL_LLM_MODEL_PATH=models/Qwen_Qwen3.5-9B-Q4_K_M.gguf

# 兼容旧配置：已有脚本仍可读取，但新代码优先使用 LOCAL_* / DEEPSEEK_*。
# LLM_MODEL=Qwen_Qwen3.5-9B-Q4_K_M.gguf
# OPENAI_API_KEY=not-needed
# OPENAI_BASE_URL=http://127.0.0.1:8080/v1

# ============================================================
# Embedding 配置（仍然本地保存向量，默认使用本地 Ollama）
# ============================================================
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5

# 2G 服务器建议优先使用远程 embedding，避免本机运行 Ollama 占用内存。
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.xxx.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# 兼容旧配置
EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=nomic-embed-text:v1.5
# EMBEDDING_MODEL=text-embedding-3-small

# MinerU PDF 解析。灾害知识文档以正文为主，默认关闭公式/表格识别以提升速度。
MINERU_BACKEND=pipeline
MINERU_ENABLE_FORMULA=false
MINERU_ENABLE_TABLE=false

# 城市地理编码。默认使用 OpenStreetMap Nominatim，并在 data/cache/geocoder_cache.json 缓存。
GEOCODER_PROVIDER=nominatim
GEOCODER_CACHE_TTL_HOURS=24
GEOCODER_USER_AGENT=georisk-disaster-query/1.0

# 舆情线索公开 API，可选。未配置时 UI 会显示配置提示，不执行搜索。
YOUTUBE_API_KEY=

# Firecrawl 联网爬取。未配置 API Key 时系统自动跳过 Firecrawl，
# 仍会使用 CENC / USGS / GDACS 官方结构化数据源。
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT_SECONDS=4
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_TIMEOUT_SECONDS=20
FIRECRAWL_SEARCH_LIMIT=4
FIRECRAWL_CACHE_TTL_SECONDS=1800

# 自然灾害定时同步。生产服务器可开启，默认每 60 分钟刷新一次事件缓存并增量入库。
DISASTER_SCHEDULER_ENABLED=false
DISASTER_SCHEDULER_INTERVAL_MINUTES=60
DISASTER_SCHEDULER_STARTUP_DELAY_SECONDS=30
DISASTER_SCHEDULER_RUN_ON_START=false

# 事件去重与可信度评分
EVENT_DEDUP_TIME_WINDOW_MINUTES=30
EVENT_DEDUP_DISTANCE_KM=50
EVENT_DEDUP_MAGNITUDE_DELTA=0.3

# ============================================================
# Neo4j 图数据库 — 知识图谱存储
# ============================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

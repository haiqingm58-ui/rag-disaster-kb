# ============================================================
# LLM 配置（OpenAI 兼容接口）
# ============================================================

# --- 方式一：llama.cpp server（本地，推荐）---
# 先启动: ./scripts/run_llama.sh <gguf模型路径>
LLM_MODEL=Qwen_Qwen3.5-9B-Q4_K_M.gguf
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
OPENAI_API_KEY=not-needed
OPENAI_BASE_URL=http://127.0.0.1:8080/v1

# --- 方式二：Ollama（本地）---
# LLM_MODEL=qwen3.5:9b
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# --- 方式三：DeepSeek / OpenAI 等云端 API ---
# LLM_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# ============================================================
# Embedding 配置
# ============================================================
EMBEDDING_BACKEND=local                       # local=Ollama, openai=远程API
LOCAL_EMBEDDING_MODEL=nomic-embed-text:v1.5   # Ollama embedding 模型
# EMBEDDING_MODEL=text-embedding-3-small       # OpenAI embedding（仅 backend=openai 时生效）

# MinerU PDF 解析。灾害知识文档以正文为主，默认关闭公式/表格识别以提升速度。
MINERU_BACKEND=pipeline
MINERU_ENABLE_FORMULA=false
MINERU_ENABLE_TABLE=false
